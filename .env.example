# Credenciales del proyecto Firebase. Conseguilas en:
# Firebase Console → Project Settings → General → Your apps → Web app → SDK setup
#
# Las 6 variables de abajo son OBLIGATORIAS. Si falta cualquiera, src/firebase/config.ts
# throw-ea al arrancar (fail-fast). Antes había fallback hardcodeado al proyecto
# mister-service-app-cloude; se quitó en SPRINT-136 (2026-05-11) por seguridad.
#
# Para dev local: copiá este archivo a `.env` y rellená los valores.
# Para Vercel: agregalas en Project Settings → Environment Variables (production + preview).

VITE_FIREBASE_API_KEY=tu-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# App Check (reCAPTCHA v3) — OPCIONAL pero recomendado.
# Sin esta key, App Check no se inicializa y los requests no llevan token de attestation.
# Conseguila en: Firebase Console → App Check → Web → reCAPTCHA v3 → Site key.
VITE_RECAPTCHA_SITE_KEY=
