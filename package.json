{
  "name": "mister-service-rd",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives",
    "preview": "vite preview",
    "deploy:rules": "npx firebase deploy --only firestore:rules && tsx scripts/invariantes/marcar-rules-deployadas.ts",
    "deploy:storage-rules": "npx firebase deploy --only storage && tsx scripts/invariantes/marcar-storage-rules-deployadas.ts",
    "deploy:indexes": "npx firebase deploy --only firestore:indexes",
    "check:regression": "tsx scripts/invariantes/run-all.ts",
    "check:regression:ci": "tsx scripts/invariantes/run-all.ts --ci",
    "audit:notis-legacy": "tsx scripts/invariantes/check-notis-legacy-data-shape.ts",
    "audit:schema-drift": "tsx scripts/auditoria/schema-drift.ts",
    "metricas": "tsx scripts/metricas-mejora-continua.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/leaflet": "^1.9.8",
    "@types/leaflet.heat": "^0.2.5",
    "@types/leaflet.markercluster": "^1.5.6",
    "date-fns": "^2.30.0",
    "firebase": "^10.7.0",
    "firebase-admin": "^12.7.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vercel/node": "^5.7.7",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "csv-parse": "^5.6.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "husky": "^9.1.7",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.0.0"
  }
}
